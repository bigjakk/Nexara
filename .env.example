# =============================================================================
# Nexara Environment Configuration
# Copy this file to .env and update values for your environment.
# =============================================================================

# ---- Database ----
POSTGRES_USER=nexara
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexara
DATABASE_URL=postgres://nexara:changeme@nexara-db:5432/nexara?sslmode=disable

# ---- Redis ----
REDIS_URL=redis://nexara-redis:6379/0

# ---- Permissions ----
# User/group ID for the Nexara process and data directory ownership.
# Set to match your host user (run `id` to check). Defaults to 1000:1000.
PUID=1000
PGID=1000

# ---- Server ----
API_PORT=8080

# ---- Secrets (optional — auto-generated on first start if omitted) ----
# Secrets are persisted to DATA_DIR/.secrets.json so they survive restarts.
# Set these explicitly only if you prefer to manage secrets externally.
#
# JWT signing secret. Generate with: openssl rand -base64 32
# JWT_SECRET=
#
# AES-256-GCM encryption key (64 hex chars / 32 bytes). Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# ---- Collector ----
METRICS_COLLECT_INTERVAL=10s

# ---- Storage ----
# Custom data directory for secrets, branding assets, uploads, etc.
# Set to an absolute path to use a bind mount (e.g. NFS share):
#   DATA_DIR=/mnt/nfs/nexara
# Leave commented to use the default Docker volume (nexara-data).
# DATA_DIR=

# ---- Logging ----
LOG_LEVEL=info

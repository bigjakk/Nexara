# =============================================================================
# ProxDash Environment Configuration
# Copy this file to .env and update values for your environment.
# =============================================================================

# ---- Database ----
POSTGRES_USER=proxdash
POSTGRES_PASSWORD=changeme
POSTGRES_DB=proxdash
DATABASE_URL=postgres://proxdash:changeme@proxdash-db:5432/proxdash?sslmode=disable

# ---- Redis ----
REDIS_URL=redis://proxdash-redis:6379/0

# ---- API Server ----
API_PORT=8080
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string
# Must be exactly 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-key

# ---- WebSocket Server ----
WS_PORT=8081

# ---- Collector ----
COLLECT_INTERVAL=30s

# ---- Scheduler ----
SCHEDULER_TICK=60s

# ---- Caddy / Domain ----
PROXDASH_DOMAIN=localhost

# ---- Logging ----
LOG_LEVEL=info

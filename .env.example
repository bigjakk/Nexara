# =============================================================================
# Nexara Environment Configuration
# Copy this file to .env and update values for your environment.
# =============================================================================

# ---- Database ----
POSTGRES_USER=nexara
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nexara
# DATABASE_URL is auto-constructed from the variables above in docker-compose.yml.

# ---- Redis ----
REDIS_URL=redis://nexara-redis:6379/0

# ---- Permissions ----
# User/group ID for the Nexara process. Match your host user (run `id` to check).
PUID=1000
PGID=1000

# ---- Secrets (optional — auto-generated on first start if omitted) ----
# JWT signing secret. Generate with: openssl rand -base64 32
# JWT_SECRET=
#
# AES-256-GCM encryption key (64 hex chars). Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# ---- Collector ----
METRICS_COLLECT_INTERVAL=10s

# ---- Logging ----
LOG_LEVEL=info

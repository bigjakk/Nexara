:80 {
    # Security headers (defense-in-depth — duplicates Go middleware for users who keep Caddy).
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # API routes — upload endpoint gets a higher limit for ISO files.
    # flush_interval -1 disables response buffering for immediate streaming.
    handle /api/v1/clusters/*/storage/*/upload {
        request_body {
            max_size 15GB
        }
        reverse_proxy nexara-api:8080 {
            flush_interval -1
            transport http {
                read_buffer  256kb
                write_buffer 256kb
            }
        }
    }

    # API routes — normal traffic capped at 10MB.
    handle /api/* {
        request_body {
            max_size 10MB
        }
        reverse_proxy nexara-api:8080
    }

    # WebSocket routes
    handle /ws {
        reverse_proxy nexara-ws:8081
    }
    handle /ws/* {
        reverse_proxy nexara-ws:8081
    }

    # Frontend (default)
    handle {
        reverse_proxy nexara-frontend:3000
    }

    # Logging
    log {
        output stdout
        format console
    }
}

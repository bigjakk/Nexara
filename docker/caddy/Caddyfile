:80 {
    # API routes
    handle /api/* {
        request_body {
            max_size 4GB
        }
        reverse_proxy nexara-api:8080
    }

    # WebSocket routes
    handle /ws {
        reverse_proxy nexara-ws:8081
    }
    handle /ws/* {
        reverse_proxy nexara-ws:8081
    }

    # Frontend (default)
    handle {
        reverse_proxy nexara-frontend:3000
    }

    # Logging
    log {
        output stdout
        format console
    }
}

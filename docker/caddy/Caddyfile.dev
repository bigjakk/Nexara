:443 {
	tls /data/caddy/dev.crt /data/caddy/dev.key

	reverse_proxy nexara:8080
}

# Redirect plain HTTP to HTTPS so credentials (incl. the refresh cookie) never
# traverse cleartext. Production proxies (operator-provided) should do the same
# and additionally emit HSTS.
:80 {
	redir https://{host}{uri} permanent
}
